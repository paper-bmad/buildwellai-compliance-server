ANTHROPIC_API_KEY=your-anthropic-api-key-here
PORT=3001

# Optional: restrict CORS to specific origins (comma-separated).
# Unset = allow all origins (fine for local dev / internal network).
# Example: ALLOWED_ORIGINS=https://app.buildwellai.com,http://localhost:5173
ALLOWED_ORIGINS=

# Optional: per-IP rate limits for inference endpoints (requests per minute).
# Set to 0 to disable. Defaults: check=10/min, analyze=5/min.
RATE_LIMIT_RPM=10
RATE_LIMIT_ANALYZE_RPM=5
